<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" /> <!-- 如果需要访问 HTTP（非 HTTPS）还需要添加 -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/arona_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/arona_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.ShoppingMall">
        <activity
            android:name=".ui.activity.DeliveryAddressActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.AboutActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.pass.ChangePasswordActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.ProductDetailsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.NavigationBarActivity"
            android:exported="false"
            android:label="@string/title_activity_navigation_bar"
            android:theme="@style/Theme.ShoppingMall" />
        <activity
            android:name=".ui.activity.login.ForgotPasswordActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.login.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.login.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".MainActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.WelcomeActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>